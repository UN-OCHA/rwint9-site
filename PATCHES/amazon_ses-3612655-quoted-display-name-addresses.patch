+  /**
+   * Split a mailbox-list into individual addresses.
+   *
+   * Unlike a naive split on commas/semicolons, this preserves separators
+   * inside quoted display names, e.g. `"John Doe, MPH" <user@example.com>`.
+   *
+   * @param string $addresses
+   *   A mailbox-list string (To, Cc, or Bcc).
+   *
+   * @return array
+   *   A list of individual address strings.
+   */
+  protected function splitAddresses(string $addresses): array {
+    // Split on commas/semicolons only when not inside double quotes.
+    // @see \Drupal\Core\Mail\Plugin\Mail\SymfonyMailer::mail() which uses
+    // str_getcsv() for the same reason.
+    // A regex is used instead of str_getcsv() so both "," and ";" remain valid
+    // address separators, matching the previous preg_split('/[,;]/') behavior.
+    $parts = preg_split('/[,;](?=(?:[^"]*"[^"]*")*[^"]*$)/', $addresses) ?: [];
+    return array_values(array_filter(array_map('trim', $parts)));
   }

