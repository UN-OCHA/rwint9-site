+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\social_auth_entra_id\Settings;
+
+use Drupal\social_auth\Settings\SettingsBase;
+
+/**
+ * Defines methods to get Social Auth Entra ID settings.
+ */
+class EntraIdAuthSettings extends SettingsBase implements EntraIdAuthSettingsInterface {
+
+  /**
+   * Tenant ID.
+   *
+   * @var string|null
+   */
+  protected ?string $tenantId = NULL;
+
+  /**
+   * Account type (organization, common, or consumers).
+   *
+   * @var string|null
+   */
+  protected ?string $accountType = NULL;
+
+  /**
+   * Allowed email domains (comma/newline separated).
+   *
+   * @var string|null
+   */
+  protected ?string $allowedDomains = NULL;
+
+  /**
+   * Whether to use legacy redirect and callback URLs.
+   *
+   * @var bool|null
+   */
+  protected ?bool $useLegacyUrls = NULL;
+
+  /**
+   * {@inheritdoc}
+   */
+  public function getTenantId(): ?string {
+    if ($this->tenantId === NULL) {
+      $this->tenantId = $this->config->get('tenant_id');
+    }
+    return $this->tenantId;
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public function getAccountType(): string {
+    if ($this->accountType === NULL) {
+      $this->accountType = $this->config->get('account_type') ?? 'organization';
+    }
+    return $this->accountType;
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public function getAllowedDomains(): array {
+    if ($this->allowedDomains === NULL) {
+      $this->allowedDomains = $this->config->get('allowed_domains') ?? '';
+    }
+    $tokens = preg_split('/[\r\n,]+/', (string) $this->allowedDomains);
+    $domains = array_filter(array_map(function ($d) {
+      return strtolower(trim($d));
+    }, $tokens ?: []));
+    return array_values($domains);
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public function useLegacyUrls(): bool {
+    if ($this->useLegacyUrls === NULL) {
+      $this->useLegacyUrls = (bool) ($this->config->get('use_legacy_urls') ?? FALSE);
+    }
+    return $this->useLegacyUrls;
+  }
+
+}
