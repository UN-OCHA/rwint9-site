+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\social_auth_entra_id\Plugin\Network;
+
+use Drupal\Core\Url;
+use Drupal\social_auth\Plugin\Network\NetworkBase;
+use Drupal\social_auth\Plugin\Network\NetworkInterface;
+use Drupal\social_auth\Settings\SettingsInterface;
+use Drupal\social_auth_entra_id\Settings\EntraIdAuthSettingsInterface;
+
+/**
+ * Defines a Network Plugin for Social Auth Microsoft Entra ID.
+ *
+ * @Network(
+ *   id = "social_auth_entra_id",
+ *   short_name = "entra_id",
+ *   social_network = "Microsoft Entra ID",
+ *   img_path = "img/entra_id_logo.svg",
+ *   type = "social_auth",
+ *   class_name = "\Drupal\social_auth_entra_id\Provider\EntraIdProvider",
+ *   auth_manager = "\Drupal\social_auth_entra_id\EntraIdAuthManager",
+ *   routes = {
+ *     "redirect": "social_auth.network.redirect",
+ *     "callback": "social_auth.network.callback",
+ *     "settings_form": "social_auth.network.settings_form",
+ *   },
+ *   handlers = {
+ *     "settings": {
+ *       "class": "\Drupal\social_auth_entra_id\Settings\EntraIdAuthSettings",
+ *       "config_id": "social_auth_entra_id.settings"
+ *     }
+ *   }
+ * )
+ */
+class EntraIdAuth extends NetworkBase implements NetworkInterface {
+
+  /**
+   * {@inheritdoc}
+   */
+  protected function getExtraSdkSettings(): array {
+    /** @var \Drupal\social_auth_entra_id\Settings\EntraIdAuthSettingsInterface $settings */
+    $settings = $this->settings;
+    $account_type = $settings->getAccountType();
+    $tenant = ($account_type === 'organization') ? ($settings->getTenantId() ?? 'common') : $account_type;
+
+    return [
+      'tenant' => $tenant,
+    ];
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  protected function validateConfig(SettingsInterface $settings): bool {
+    if (!$settings->getClientId() || !$settings->getClientSecret()) {
+      $this->loggerFactory
+        ->get($this->pluginId)
+        ->error('Define Client ID and Client Secret in module settings.');
+      return FALSE;
+    }
+    if ($settings->getAccountType() === 'organization' && empty($settings->getTenantId())) {
+      $this->loggerFactory
+        ->get($this->pluginId)
+        ->error('Tenant ID is required for organization account type.');
+      return FALSE;
+    }
+    return TRUE;
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public function getRedirectUrl(array $route_options = []): Url {
+    if ($this->settings instanceof EntraIdAuthSettingsInterface && $this->settings->useLegacyUrls()) {
+      return Url::fromRoute('social_auth_entra_id.redirect', [], $route_options);
+    }
+    return parent::getRedirectUrl($route_options);
+  }
+
+  /**
+   * {@inheritdoc}
+   */
+  public function getCallbackUrl(array $route_options = []): Url {
+    if ($this->settings instanceof EntraIdAuthSettingsInterface && $this->settings->useLegacyUrls()) {
+      return Url::fromRoute('social_auth_entra_id.callback', [], $route_options);
+    }
+    return parent::getCallbackUrl($route_options);
+  }
+
+}
