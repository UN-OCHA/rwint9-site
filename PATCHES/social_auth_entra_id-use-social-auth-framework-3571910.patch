+<?php
+
+/**
+ * @file
+ * Install, update, and uninstall functions for the Social Auth Entra ID module.
+ */
+
+/**
+ * Implements hook_update_N().
+ *
+ * Remove deprecated config keys after migration to social_auth base.
+ * Login behavior and admin restrictions now use social_auth.settings.
+ */
+function social_auth_entra_id_update_11000(&$sandbox) {
+  $config = \Drupal::configFactory()->getEditable('social_auth_entra_id.settings');
+  $config
+    ->clear('login_behavior')
+    ->clear('block_user_1')
+    ->clear('block_admin_role')
+    ->save();
+}
