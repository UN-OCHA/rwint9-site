++<?php
++
++declare(strict_types=1);
++
++namespace Drupal\social_auth_entra_id;
++
++use Drupal\Core\Config\ConfigFactoryInterface;
++use Drupal\Core\Logger\LoggerChannelFactoryInterface;
++use Drupal\Core\Utility\Error;
++use Drupal\social_auth\AuthManager\OAuth2Manager;
++use Drupal\social_auth\User\SocialAuthUser;
++use Drupal\social_auth\User\SocialAuthUserInterface;
++use Drupal\social_auth_entra_id\Settings\EntraIdAuthSettingsInterface;
++use League\OAuth2\Client\Provider\Exception\IdentityProviderException;
++use Symfony\Component\HttpFoundation\RequestStack;
++
++/**
++ * Contains all the logic for Microsoft Entra ID OAuth2 authentication.
++ */
++class EntraIdAuthManager extends OAuth2Manager {
++
++  /**
++   * {@inheritdoc}
++   */
++  public function __construct(
++    ConfigFactoryInterface $configFactory,
++    LoggerChannelFactoryInterface $logger_factory,
++    RequestStack $request_stack,
++  ) {
++    parent::__construct(
++      $configFactory->get('social_auth_entra_id.settings'),
++      $logger_factory,
++      $request_stack->getCurrentRequest(),
++    );
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function authenticate(): void {
++    if ($code = $this->request->query->get('code')) {
++      try {
++        $this->setAccessToken($this->client->getAccessToken('authorization_code', ['code' => $code]));
++      }
++      catch (\Throwable $exception) {
++        $this->loggerFactory->get('social_auth_entra_id')->error(
++          'There was an error during authentication. ' . Error::DEFAULT_ERROR_MESSAGE . ' @backtrace_string',
++          Error::decodeException($exception)
++        );
++      }
++    }
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getUserInfo(): ?SocialAuthUserInterface {
++    if (!$this->user && $access_token = $this->getAccessToken()) {
++      /** @var \Drupal\social_auth_entra_id\Provider\EntraIdProvider $client */
++      $client = $this->client;
++      /** @var \Drupal\social_auth_entra_id\Provider\EntraIdResourceOwnerInterface $owner */
++      $owner = $client->getResourceOwner($access_token);
++
++      $provider_user_id = $owner->getId();
++      if ($provider_user_id === NULL) {
++        return NULL;
++      }
++
++      $name = $owner->getName();
++      if ($name === NULL) {
++        return NULL;
++      }
++
++      $email = $owner->getEmail();
++      if ($email === NULL) {
++        return NULL;
++      }
++
++      // Enforce allowed domains if configured.
++      $settings = $this->settings;
++      if ($settings instanceof EntraIdAuthSettingsInterface) {
++        $allowed = $settings->getAllowedDomains();
++        if (!empty($allowed)) {
++          $domain = strtolower(substr(strrchr($email, '@'), 1));
++          if (!in_array($domain, $allowed, TRUE)) {
++            $this->loggerFactory->get('social_auth_entra_id')->notice(
++              'Login attempt from disallowed domain: @email',
++              ['@email' => $email]
++            );
++            return NULL;
++          }
++        }
++      }
++
++      $this->user = new SocialAuthUser(
++        $name,
++        $provider_user_id,
++        (string) $access_token,
++        $email,
++        NULL,
++        $this->getExtraDetails()
++      );
++      $this->user->setFirstName($owner->getFirstName());
++      $this->user->setLastName($owner->getLastName());
++    }
++    return $this->user;
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getAuthorizationUrl(): string {
++    $scopes = ['openid', 'profile', 'email', 'User.Read'];
++    $extra_scopes = $this->getScopes();
++    if ($extra_scopes) {
++      $scopes = array_merge($scopes, array_map('trim', explode(',', $extra_scopes)));
++    }
++    return $this->client->getAuthorizationUrl([
++      'scope' => $scopes,
++    ]);
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function requestEndPoint(string $method, string $path, ?string $domain = NULL, array $options = []): mixed {
++    if (!$domain) {
++      $domain = 'https://graph.microsoft.com';
++    }
++    $url = $domain . $path;
++    $request = $this->client->getAuthenticatedRequest($method, $url, $this->getAccessToken(), $options);
++    try {
++      return $this->client->getParsedResponse($request);
++    }
++    catch (IdentityProviderException $exception) {
++      $this->loggerFactory->get('social_auth_entra_id')
++        ->error('There was an error when requesting @url. Exception: @message', [
++          '@url' => $url,
++          '@message' => $exception->getMessage(),
++        ]);
++    }
++    return NULL;
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getState(): string {
++    return $this->client->getState();
++  }
++
++}
