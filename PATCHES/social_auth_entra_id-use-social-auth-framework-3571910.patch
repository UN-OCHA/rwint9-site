++<?php
++
++declare(strict_types=1);
++
++namespace Drupal\social_auth_entra_id\Provider;
++
++use League\OAuth2\Client\Provider\AbstractProvider;
++use League\OAuth2\Client\Provider\Exception\IdentityProviderException;
++use League\OAuth2\Client\Token\AccessToken;
++use League\OAuth2\Client\Tool\BearerAuthorizationTrait;
++use Psr\Http\Message\ResponseInterface;
++
++/**
++ * Microsoft Entra ID (Azure AD) OAuth2 provider using League OAuth2 Client.
++ *
++ * Consistent with league/oauth2-google and league/oauth2-linkedin: resource
++ * owner details are fetched via an API call (Microsoft Graph /me), not from
++ * decoding the id_token. The id_token remains in token values for consumers
++ * that want to parse it.
++ *
++ * @see https://learn.microsoft.com/en-us/entra/identity-platform/v2-oauth2-auth-code-flow
++ * @see https://learn.microsoft.com/en-us/graph/api/user-get
++ */
++class EntraIdProvider extends AbstractProvider {
++
++  use BearerAuthorizationTrait;
++
++  /**
++   * Base URL for Microsoft login.
++   *
++   * @var string
++   */
++  protected string $urlLogin = 'https://login.microsoftonline.com/';
++
++  /**
++   * Tenant: tenant ID, 'common', or 'consumers'.
++   *
++   * @var string
++   */
++  protected string $tenant = 'common';
++
++  /**
++   * Constructor.
++   *
++   * @param array<string, mixed> $options
++   *   Options: clientId, clientSecret, redirectUri, tenant.
++   * @param array $collaborators
++   *   Optional collaborators (httpClient, etc.).
++   */
++  public function __construct(array $options = [], array $collaborators = []) {
++    if (isset($options['tenant'])) {
++      $this->tenant = $options['tenant'];
++    }
++    parent::__construct($options, $collaborators);
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getBaseAuthorizationUrl(): string {
++    return $this->urlLogin . $this->tenant . '/oauth2/v2.0/authorize';
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getBaseAccessTokenUrl(array $params): string {
++    return $this->urlLogin . $this->tenant . '/oauth2/v2.0/token';
++  }
++
++  /**
++   * {@inheritdoc}
++   *
++   * Microsoft Graph /me endpoint for resource owner details (like Google
++   * userinfo and LinkedIn /v2/me).
++   */
++  public function getResourceOwnerDetailsUrl(AccessToken $token): string {
++    return 'https://graph.microsoft.com/v1.0/me';
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  protected function getDefaultScopes(): array {
++    return ['openid', 'profile', 'email', 'User.Read'];
++  }
++
++  /**
++   * {@inheritdoc}
++   *
++   * Microsoft uses space-separated scopes.
++   */
++  protected function getScopeSeparator(): string {
++    return ' ';
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  protected function checkResponse(ResponseInterface $response, $data): void {
++    if (!empty($data['error'])) {
++      $message = $data['error_description'] ?? $data['error'];
++      if (is_array($message)) {
++        $message = $message['value'] ?? (string) json_encode($message);
++      }
++      throw new IdentityProviderException(
++        (string) $message,
++        $response->getStatusCode(),
++        (string) $response->getBody()
++      );
++    }
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  protected function createResourceOwner(array $response, AccessToken $token): EntraIdResourceOwnerInterface {
++    return new EntraIdResourceOwner($response);
++  }
++
++}
+diff --git a/src/Provider/EntraIdResourceOwner.php b/src/Provider/EntraIdResourceOwner.php
+new file mode 100644
+index 0000000000000000000000000000000000000000..35650ce47f59624125bdd2060d9611bd83af65a4
+--- /dev/null
++++ b/src/Provider/EntraIdResourceOwner.php
+@@ -0,0 +1,158 @@
++<?php
++
++declare(strict_types=1);
++
++namespace Drupal\social_auth_entra_id\Provider;
++
++/**
++ * Microsoft Entra ID resource owner (Microsoft Graph /me response).
++ *
++ * Maps Microsoft Graph API user response to a simple interface, consistent
++ * with league/oauth2-google (userinfo response) and league/oauth2-linkedin
++ * (/v2/me response). Graph returns: id, displayName, mail, userPrincipalName,
++ * givenName, surname, etc.
++ *
++ * @see https://learn.microsoft.com/en-us/graph/api/user-get
++ */
++class EntraIdResourceOwner implements EntraIdResourceOwnerInterface {
++
++  /**
++   * Raw response from Microsoft Graph /me.
++   *
++   * @var array<string, mixed>
++   */
++  protected array $response;
++
++  /**
++   * Constructor.
++   *
++   * @param array<string, mixed> $response
++   *   Response from GET https://graph.microsoft.com/v1.0/me.
++   */
++  public function __construct(array $response = []) {
++    $this->response = $response;
++  }
++
++  /**
++   * Gets a value from the response by key.
++   *
++   * @param string $key
++   *   Response key (e.g. id, displayName, mail).
++   *
++   * @return mixed|null
++   *   Value or NULL.
++   */
++  protected function getResponseValue(string $key) {
++    return $this->response[$key] ?? NULL;
++  }
++
++  /**
++   * Gets a value from the response by key as a string if it is not NULL.
++   *
++   * @param string $key
++   *   Response key (e.g. id, displayName, mail).
++   *
++   * @return string|null
++   *   Value or NULL.
++   */
++  protected function getResponseStringValue(string $key): ?string {
++    $value = $this->getResponseValue($key);
++    return $value !== NULL ? trim((string) $value) : NULL;
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getId(): ?string {
++    return $this->getResponseStringValue('id');
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getName(): ?string {
++    $display_name = $this->getResponseStringValue('displayName') ?? '';
++    if ($display_name !== '') {
++      return $display_name;
++    }
++
++    $preferred_username = $this->getPreferredUsername() ?? '';
++    if ($preferred_username !== '') {
++      return $preferred_username;
++    }
++
++    $user_principal_name = $this->getUserPrincipalName() ?? '';
++    if ($user_principal_name !== '') {
++      return $user_principal_name;
++    }
++
++    $first = $this->getFirstName() ?? '';
++    $last = $this->getLastName() ?? '';
++    if ($first !== '' || $last !== '') {
++      return trim($first . ' ' . $last);
++    }
++
++    $email = $this->getEmail() ?? '';
++    if ($email !== '') {
++      return $email;
++    }
++
++    $id = $this->getId() ?? '';
++    if ($id !== '') {
++      return $id;
++    }
++
++    return NULL;
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getFirstName(): ?string {
++    return $this->getResponseStringValue('givenName');
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getLastName(): ?string {
++    return $this->getResponseStringValue('surname');
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getEmail(): ?string {
++    $mail = $this->getResponseStringValue('mail');
