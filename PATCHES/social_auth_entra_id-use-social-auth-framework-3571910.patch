+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\Tests\social_auth_entra_id\Unit;
+
+use Drupal\Core\Logger\LoggerChannelFactoryInterface;
+use Drupal\Core\Logger\LoggerChannelInterface;
+use Drupal\social_auth_entra_id\EntraIdAuthManager;
+use Drupal\social_auth_entra_id\Provider\EntraIdResourceOwnerInterface;
+use Drupal\Tests\UnitTestCase;
+use League\OAuth2\Client\Provider\GenericProvider;
+use League\OAuth2\Client\Token\AccessToken;
+use PHPUnit\Framework\Attributes\CoversClass;
+use PHPUnit\Framework\Attributes\Group;
+use PHPUnit\Framework\Attributes\IgnoreDeprecations;
+use Symfony\Component\HttpFoundation\Request;
+use Symfony\Component\HttpFoundation\RequestStack;
+
+/**
+ * Tests EntraIdAuthManager.
+ */
+#[Group('social_auth_entra_id')]
+#[CoversClass(EntraIdAuthManager::class)]
+#[IgnoreDeprecations]
+final class EntraIdAuthManagerTest extends UnitTestCase {
+
+  /**
+   * Tests getAuthorizationUrl returns a URL with expected scopes.
+   */
+  public function testGetAuthorizationUrl(): void {
+    $config_factory = $this->getConfigFactoryStub([
+      'social_auth_entra_id.settings' => [
+        'client_id' => 'test-client',
+        'client_secret' => 'test-secret',
+        'scopes' => '',
+      ],
+    ]);
+    $logger = $this->createMock(LoggerChannelInterface::class);
+    $logger_factory = $this->createMock(LoggerChannelFactoryInterface::class);
+    $logger_factory->method('get')->with('social_auth_entra_id')->willReturn($logger);
+
+    $request = Request::create('/');
+    $request_stack = new RequestStack();
+    $request_stack->push($request);
+
+    $manager = new EntraIdAuthManager($config_factory, $logger_factory, $request_stack);
+
+    // Set client via reflection so getAuthorizationUrl can run.
+    $client = new GenericProvider([
+      'clientId' => 'test',
+      'clientSecret' => 'secret',
+      'urlAuthorize' => 'https://login.microsoftonline.com/common/oauth2/v2.0/authorize',
+      'urlAccessToken' => 'https://login.microsoftonline.com/common/oauth2/v2.0/token',
+      'urlResourceOwnerDetails' => 'https://graph.microsoft.com/v1.0/me',
+    ]);
+    $ref = new \ReflectionProperty($manager, 'client');
+    $ref->setValue($manager, $client);
+
+    $url = $manager->getAuthorizationUrl();
+    self::assertStringContainsString('login.microsoftonline.com', $url);
+    self::assertStringContainsString('openid', $url);
+    self::assertStringContainsString('profile', $url);
+    self::assertStringContainsString('User.Read', $url);
+  }
+
+  /**
+   * Tests getUserInfo returns user when resource owner data is present.
+   *
+   * Uses the real config from the stub (ImmutableConfig). The allowed-domains
+   * path is not exercised here because $this->settings is ImmutableConfig,
+   * not EntraIdAuthSettingsInterface. That behavior is covered by Kernel tests
+   * when config and plugin are used together.
+   */
+  public function testGetUserInfoReturnsUser(): void {
+    $config_factory = $this->getConfigFactoryStub([
+      'social_auth_entra_id.settings' => [
+        'client_id' => 'test',
+        'client_secret' => 'secret',
+        'scopes' => '',
+        'endpoints' => '',
+      ],
+    ]);
+    $logger_factory = $this->createMock(LoggerChannelFactoryInterface::class);
+    $logger_factory->method('get')->willReturn($this->createMock(LoggerChannelInterface::class));
+
+    $request = Request::create('/');
+    $request_stack = new RequestStack();
+    $request_stack->push($request);
+
+    $manager = new EntraIdAuthManager($config_factory, $logger_factory, $request_stack);
+
+    $owner = $this->createMock(EntraIdResourceOwnerInterface::class);
+    $owner->method('getId')->willReturn('id-1');
+    $owner->method('getName')->willReturn('User');
+    $owner->method('getEmail')->willReturn('user@example.com');
+    $owner->method('getFirstName')->willReturn('First');
+    $owner->method('getLastName')->willReturn('Last');
+
+    $token = new AccessToken(['access_token' => 'token']);
+    $client = $this->createMock(GenericProvider::class);
+    $client->method('getResourceOwner')->with($token)->willReturn($owner);
+
+    $ref_client = new \ReflectionProperty($manager, 'client');
+    $ref_client->setValue($manager, $client);
+    $ref_token = new \ReflectionProperty($manager, 'accessToken');
+    $ref_token->setValue($manager, $token);
+
+    $user = $manager->getUserInfo();
+    self::assertNotNull($user);
+    self::assertSame('User', $user->getName());
+    self::assertSame('user@example.com', $user->getEmail());
+  }
+
+}
