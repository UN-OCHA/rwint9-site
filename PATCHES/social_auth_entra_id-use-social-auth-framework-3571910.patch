+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\social_auth_entra_id\Provider;
+
+use League\OAuth2\Client\Provider\ResourceOwnerInterface;
+
+/**
+ * Interface for Microsoft Entra ID resource owner.
+ *
+ * Represents the public API for user data from Microsoft Graph /me response.
+ */
+interface EntraIdResourceOwnerInterface extends ResourceOwnerInterface {
+
+  /**
+   * Display name.
+   *
+   * Fallback order: displayName, preferredUsername, userPrincipalName,
+   * givenName + surname, mail, id.
+   *
+   * @return string|null
+   *   The display name or NULL.
+   */
+  public function getName(): ?string;
+
+  /**
+   * First name.
+   *
+   * Graph: givenName.
+   *
+   * @return string|null
+   *   The given name or NULL.
+   */
+  public function getFirstName(): ?string;
+
+  /**
+   * Last name.
+   *
+   * Graph: surname.
+   *
+   * @return string|null
+   *   The surname or NULL.
+   */
+  public function getLastName(): ?string;
+
+  /**
+   * Email.
+   *
+   * Graph: mail or userPrincipalName if it is an email address.
+   *
+   * @return string|null
+   *   Valid email address or NULL.
+   */
+  public function getEmail(): ?string;
+
+  /**
+   * Preferred username.
+   *
+   * Graph: userPrincipalName.
+   *
+   * @return string|null
+   *   The preferred username or NULL.
+   */
+  public function getPreferredUsername(): ?string;
+
+  /**
+   * User principal name.
+   *
+   * Graph: userPrincipalName.
+   *
+   * @return string|null
+   *   The user principal name or NULL.
+   */
+  public function getUserPrincipalName(): ?string;
+
+}
