++<?php
++
++declare(strict_types=1);
++
++namespace Drupal\social_auth_entra_id\Form;
++
++use Drupal\Core\Render\Element;
++use Drupal\Core\Form\FormStateInterface;
++use Drupal\social_auth\Form\SocialAuthSettingsForm;
++use Drupal\social_auth\Plugin\Network\NetworkInterface;
++
++/**
++ * Settings form for Social Auth Microsoft Entra ID.
++ */
++class EntraIdAuthSettingsForm extends SocialAuthSettingsForm {
++
++  /**
++   * {@inheritdoc}
++   */
++  public function getFormId(): string {
++    return 'social_auth_entra_id_settings';
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  protected function getEditableConfigNames(): array {
++    return array_merge(
++      parent::getEditableConfigNames(),
++      ['social_auth_entra_id.settings']
++    );
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function buildForm(array $form, FormStateInterface $form_state, ?NetworkInterface $network = NULL): array {
++    $network = $this->networkManager->createInstance('social_auth_entra_id');
++    $form = parent::buildForm($form, $form_state, $network);
++
++    $config = $this->config('social_auth_entra_id.settings');
++
++    // Add weights to the existing form elements so we can position the
++    // legacy URLs checkbox after the authorized redirect URL field.
++    $weight = 1;
++    foreach (Element::children($form['network']) as $key) {
++      $form['network'][$key]['#weight'] = $weight++;
++    }
++
++    // Use legacy redirect and callback URLs.
++    $form['network']['use_legacy_urls'] = [
++      '#type' => 'checkbox',
++      '#title' => $this->t('Use legacy redirect and callback URLs'),
++      '#default_value' => $config->get('use_legacy_urls') ?? FALSE,
++      '#description' => $this->t('Use the legacy redirect and callback URLs (<code>/user/login/entra-id</code> and <code>/user/login/entra-id/callback</code>) for backward compatibility with Azure app registrations.'),
++      '#weight' => $form['network']['authorized_redirect_url']['#weight'] + 0.1,
++    ];
++
++    // Hide the authorized redirect URL field when using legacy URLs.
++    $form['network']['authorized_redirect_url']['#states'] = [
++      'visible' => [
++        ':input[name="use_legacy_urls"]' => ['checked' => FALSE],
++      ],
++    ];
++
++    $form['network']['tenant_id'] = [
++      '#type' => 'textfield',
++      '#title' => $this->t('Tenant ID'),
++      '#default_value' => $config->get('tenant_id'),
++      '#description' => $this->t('Directory (tenant) ID from Azure Active Directory. Only required for organization accounts (single-tenant).'),
++      '#required' => FALSE,
++      '#states' => [
++        'required' => [
++          ':input[name="account_type"]' => ['value' => 'organization'],
++        ],
++        'visible' => [
++          ':input[name="account_type"]' => ['value' => 'organization'],
++        ],
++      ],
++      '#weight' => $weight++,
++    ];
++
++    $form['network']['account_type'] = [
++      '#type' => 'radios',
++      '#title' => $this->t('Account type'),
++      '#options' => [
++        'organization' => $this->t('Organization accounts only (single tenant)'),
++        'common' => $this->t('Both organization and personal Microsoft accounts'),
++        'consumers' => $this->t('Personal Microsoft accounts only'),
++      ],
++      '#default_value' => $config->get('account_type') ?? 'organization',
++      '#description' => $this->t('Choose what types of Microsoft accounts can authenticate.'),
++      '#weight' => $weight++,
++    ];
++
++    $form['network']['allowed_domains'] = [
++      '#type' => 'textarea',
++      '#title' => $this->t('Allowed domains'),
++      '#default_value' => $config->get('allowed_domains'),
++      '#description' => $this->t('Optionally restrict login to these email domains (comma or newline separated). Leave empty to allow all.'),
++      '#weight' => $weight++,
++    ];
++
++    return $form;
++  }
++
++  /**
++   * {@inheritdoc}
++   */
++  public function submitForm(array &$form, FormStateInterface $form_state): void {
++    $values = $form_state->getValues();
++    $this->configFactory->getEditable('social_auth_entra_id.settings')
++      ->set('use_legacy_urls', (bool) ($values['use_legacy_urls'] ?? FALSE))
++      ->set('tenant_id', trim((string) ($values['tenant_id'] ?? '')))
++      ->set('account_type', (string) ($values['account_type'] ?? 'organization'))
++      ->set('allowed_domains', trim((string) ($values['allowed_domains'] ?? '')))
++      ->save();
++
++    parent::submitForm($form, $form_state);
++  }
++
++}
