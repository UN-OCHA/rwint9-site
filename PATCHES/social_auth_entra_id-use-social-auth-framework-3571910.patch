+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\Tests\social_auth_entra_id\Unit;
+
+use Drupal\Core\Config\ImmutableConfig;
+use Drupal\social_auth_entra_id\Settings\EntraIdAuthSettings;
+use Drupal\Tests\UnitTestCase;
+use PHPUnit\Framework\Attributes\CoversClass;
+use PHPUnit\Framework\Attributes\Group;
+use PHPUnit\Framework\Attributes\IgnoreDeprecations;
+
+/**
+ * Tests EntraIdAuthSettings getters.
+ */
+#[Group('social_auth_entra_id')]
+#[CoversClass(EntraIdAuthSettings::class)]
+#[IgnoreDeprecations]
+final class EntraIdAuthSettingsTest extends UnitTestCase {
+
+  /**
+   * Creates a settings instance with the given config values.
+   *
+   * @param array $config_values
+   *   Config key-value pairs (e.g. tenant_id, account_type).
+   *
+   * @return \Drupal\social_auth_entra_id\Settings\EntraIdAuthSettings
+   *   The settings instance.
+   */
+  private function createSettings(array $config_values): EntraIdAuthSettings {
+    $config = $this->createMock(ImmutableConfig::class);
+    $config->method('get')->willReturnCallback(function ($key) use ($config_values) {
+      return $config_values[$key] ?? NULL;
+    });
+    return new EntraIdAuthSettings($config);
+  }
+
+  /**
+   * Tests getTenantId and getAccountType.
+   */
+  public function testTenantAndAccountType(): void {
+    $settings = $this->createSettings([
+      'tenant_id' => 'tenant-123',
+      'account_type' => 'common',
+    ]);
+    self::assertSame('tenant-123', $settings->getTenantId());
+    self::assertSame('common', $settings->getAccountType());
+
+    $settings = $this->createSettings([]);
+    self::assertNull($settings->getTenantId());
+    self::assertSame('organization', $settings->getAccountType());
+  }
+
+  /**
+   * Tests getAllowedDomains parsing.
+   */
+  public function testGetAllowedDomains(): void {
+    $settings = $this->createSettings(['allowed_domains' => '']);
+    self::assertSame([], $settings->getAllowedDomains());
+
+    $settings = $this->createSettings([
+      'allowed_domains' => "  Example.COM  \n  second.org  , third.net  ",
+    ]);
+    self::assertSame(['example.com', 'second.org', 'third.net'], $settings->getAllowedDomains());
+  }
+
+  /**
+   * Tests useLegacyUrls.
+   */
+  public function testUseLegacyUrls(): void {
+    $settings = $this->createSettings([]);
+    self::assertFalse($settings->useLegacyUrls());
+
+    $settings = $this->createSettings(['use_legacy_urls' => TRUE]);
+    self::assertTrue($settings->useLegacyUrls());
+  }
+
+}
