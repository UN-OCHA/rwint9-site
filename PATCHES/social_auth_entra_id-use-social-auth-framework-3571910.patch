+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\Tests\social_auth_entra_id\Kernel;
+
+use Drupal\KernelTests\KernelTestBase;
+use Drupal\social_auth_entra_id\Provider\EntraIdResourceOwner;
+use PHPUnit\Framework\Attributes\CoversClass;
+use PHPUnit\Framework\Attributes\Group;
+
+/**
+ * Tests EntraIdResourceOwner (Microsoft Graph /me response mapping).
+ */
+#[Group('social_auth_entra_id')]
+#[CoversClass(EntraIdResourceOwner::class)]
+final class EntraIdResourceOwnerTest extends KernelTestBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  protected static $modules = ['social_auth_entra_id'];
+
+  /**
+   * Tests getId returns the id from the response.
+   */
+  public function testGetId(): void {
+    $owner = new EntraIdResourceOwner(['id' => 'graph-user-123']);
+    self::assertSame('graph-user-123', $owner->getId());
+
+    $owner = new EntraIdResourceOwner([]);
+    self::assertNull($owner->getId());
+  }
+
+  /**
+   * Tests getName falls back through displayName, preferred_username, etc.
+   */
+  public function testGetName(): void {
+    $owner = new EntraIdResourceOwner([
+      'id' => 'uid',
+      'displayName' => 'Display Name',
+      'userPrincipalName' => 'user@example.com',
+      'givenName' => 'Given',
+      'surname' => 'Surname',
+      'mail' => 'mail@example.com',
+    ]);
+    self::assertSame('Display Name', $owner->getName());
+
+    $owner = new EntraIdResourceOwner([
+      'id' => 'uid',
+      'userPrincipalName' => 'upn@example.com',
+    ]);
+    self::assertSame('upn@example.com', $owner->getName());
+
+    $owner = new EntraIdResourceOwner([
+      'id' => 'uid',
+      'givenName' => 'First',
+      'surname' => 'Last',
+    ]);
+    self::assertSame('First Last', $owner->getName());
+
+    $owner = new EntraIdResourceOwner(['id' => 'uid']);
+    self::assertSame('uid', $owner->getName());
+
+    $owner = new EntraIdResourceOwner([]);
+    self::assertNull($owner->getName());
+  }
+
+  /**
+   * Tests getFirstName and getLastName.
+   */
+  public function testGetFirstAndLastName(): void {
+    $owner = new EntraIdResourceOwner([
+      'givenName' => 'Jane',
+      'surname' => 'Doe',
+    ]);
+    self::assertSame('Jane', $owner->getFirstName());
+    self::assertSame('Doe', $owner->getLastName());
+
+    $owner = new EntraIdResourceOwner([]);
+    self::assertNull($owner->getFirstName());
+    self::assertNull($owner->getLastName());
+  }
+
+  /**
+   * Tests getEmail prefers mail, then userPrincipalName if valid email.
+   */
+  public function testGetEmail(): void {
+    $owner = new EntraIdResourceOwner([
+      'mail' => 'real@example.com',
+      'userPrincipalName' => 'upn@example.com',
+    ]);
+    self::assertSame('real@example.com', $owner->getEmail());
+
+    $owner = new EntraIdResourceOwner([
+      'userPrincipalName' => 'email@example.com',
+    ]);
+    self::assertSame('email@example.com', $owner->getEmail());
+
+    $owner = new EntraIdResourceOwner([
+      'userPrincipalName' => 'not-an-email',
+    ]);
+    self::assertNull($owner->getEmail());
+
+    $owner = new EntraIdResourceOwner([]);
+    self::assertNull($owner->getEmail());
+  }
+
+  /**
+   * Tests toArray returns the raw response.
+   */
+  public function testToArray(): void {
+    $response = ['id' => '1', 'displayName' => 'Test'];
+    $owner = new EntraIdResourceOwner($response);
+    self::assertSame($response, $owner->toArray());
+  }
+
+}
