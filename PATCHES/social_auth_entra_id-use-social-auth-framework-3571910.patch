+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\Tests\social_auth_entra_id\Kernel;
+
+use Drupal\KernelTests\KernelTestBase;
+use Drupal\social_auth\Plugin\Network\NetworkInterface;
+use Drupal\social_auth_entra_id\Plugin\Network\EntraIdAuth;
+use PHPUnit\Framework\Attributes\CoversClass;
+use PHPUnit\Framework\Attributes\Group;
+
+/**
+ * Tests Entra ID plugin redirect/callback URLs based on config (legacy URLs).
+ */
+#[Group('social_auth_entra_id')]
+#[CoversClass(EntraIdAuth::class)]
+final class EntraIdAuthSettingsTest extends KernelTestBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  protected static $modules = ['social_api', 'social_auth', 'social_auth_entra_id'];
+
+  /**
+   * Returns the Entra ID network plugin.
+   */
+  private function getPlugin(): NetworkInterface {
+    return $this->container->get('plugin.network.manager')
+      ->createInstance('social_auth_entra_id');
+  }
+
+  /**
+   * Tests redirect/callback URLs with legacy URLs enabled.
+   */
+  public function testLegacyUrls(): void {
+    $this->config('social_auth_entra_id.settings')
+      ->set('client_id', 'test-client')
+      ->set('client_secret', 'test-secret')
+      ->set('use_legacy_urls', TRUE)
+      ->save();
+
+    $plugin = $this->getPlugin();
+    $redirect = $plugin->getRedirectUrl()->toString();
+    $callback = $plugin->getCallbackUrl()->toString();
+
+    self::assertStringContainsString('/user/login/entra-id', $redirect);
+    self::assertStringContainsString('/user/login/entra-id/callback', $callback);
+  }
+
+  /**
+   * Tests redirect/callback URLs with legacy URLs disabled.
+   */
+  public function testDefaultUrls(): void {
+    $this->config('social_auth_entra_id.settings')
+      ->set('client_id', 'test-client')
+      ->set('client_secret', 'test-secret')
+      ->set('use_legacy_urls', FALSE)
+      ->save();
+
+    $plugin = $this->getPlugin();
+    $redirect = $plugin->getRedirectUrl()->toString();
+    $callback = $plugin->getCallbackUrl()->toString();
+
+    self::assertStringContainsString('/user/login/entra_id', $redirect);
+    self::assertStringContainsString('/user/login/entra_id/callback', $callback);
+  }
+
+}
