+        'organization' => $this->t('Organization accounts only (single tenant)'),
+        'common' => $this->t('Both organization and personal Microsoft accounts'),
+        'consumers' => $this->t('Personal Microsoft accounts only'),
+      ],
+      '#default_value' => $config->get('account_type') ?? 'organization',
+      '#description' => $this->t('Choose what types of Microsoft accounts can authenticate.'),
+      '#weight' => $weight++,
